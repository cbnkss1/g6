# ═══ 운영 체크리스트 (대화·배포 맥락 반영) ═══════════════════════════════════════
# 1) The Odds API 키 → GAME_PLATFORM_THE_ODDS_API_KEY (Git 커밋 금지, .env 만)
# 2) Plxmed 카지노: PLXMED_* + 카탈로그는 플레이어 웹이 gp-api만 호출(GET /api/player/games/casino/providers|games).
#    업스트림(V6 등) 베이스: 비우면 V6_API_BASE 사용.
# GAME_PLATFORM_V6_API_BASE=http://127.0.0.1:8000
# GAME_PLATFORM_V6_CASINO_CATALOG_BASE=https://slotpass.net
# 3) 파워볼 cron → POST /internal/powerball/poll (한 서버만 돌리거나 락으로 이중화 시 충돌 방지)
# 4) 공개 도메인 예: 플레이어 as.slotpass.net · 어드민 test.slotpass.net · API test-api.slotpass.net
# 5) 점검: GET /internal/game-apis/status (헤더 X-Internal-Key)
# 6) Nginx: API 전용 ../docs/nginx/game_platform_api_proxy.conf.example
#    플레이어 as.slotpass.net: ../docs/nginx/as.slotpass-web-public.conf.example (전부 Next→/_next·/gp-api 정상)
#
# PostgreSQL (game_platform 전용 DB 권장). pydantic 접두사: GAME_PLATFORM_
GAME_PLATFORM_DATABASE_URL=postgresql+psycopg2://user:pass@127.0.0.1:5432/game_platform

# 개발 시에만: 앱 기동 시 테이블 자동 생성 (운영은 Alembic 권장)
GAME_PLATFORM_AUTO_CREATE_TABLES=false

# (선택) 레거시 정적 어드민 토큰 — WS 폴백용. JWT만 쓰면 비워도 됩니다.
GAME_PLATFORM_ADMIN_API_TOKEN=

# JWT (어드민 로그인 POST /admin/login)
GAME_PLATFORM_JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
GAME_PLATFORM_JWT_ALGORITHM=HS256
GAME_PLATFORM_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 정산 콜백 (헤더 X-Internal-Key)
GAME_PLATFORM_INTERNAL_API_KEY=change-me-internal

# (선택) API(uvicorn) 기동 시 gp_users 플레이어 자동 생성·비번 재설정. 콤마로 여러 명: a:1,b:2
# 운영에서 as.slotpass 로그인용 데모 계정을 스크립트 없이 맞출 때만 켜고, 끝나면 비우는 것을 권장.
# GAME_PLATFORM_BOOTSTRAP_PLAYERS=test:1234

# (선택) 주소창으로 GET /api/player/login 열었을 때 플레이어 웹 메인으로 보냄(로그인 모달 자동 오픈). 비우면 한글 안내 HTML.
# GAME_PLATFORM_PLAYER_WEB_HOME_URL=https://as.slotpass.net

# 플레이어 로그인: 기본 False = gp_users(/api/player/login)만. True일 때만 POST /api/player/login/v6 노출
# GAME_PLATFORM_PLAYER_LOGIN_V6_ENABLED=false

# ═══ 파워볼 외부 피드 (poll → 회차 저장·배팅 정산) ═══════════════════════════
# 응답 JSON: 최상위에 POWERBALL_GAME_KEY 이름의 객체, 안에 std_round, num, pb, sum (기존 v6 엔진 스펙)
# GAME_PLATFORM_POWERBALL_ENABLED=true
# GAME_PLATFORM_POWERBALL_API_URL=http://111.92.246.124:3001/get_result?game=all
# GAME_PLATFORM_POWERBALL_GAME_KEY=coinpowerball3
# 콤마 구분 다종목 (get_result?game=all JSON 최상위 키와 동일). 미설정 시 기본 5종(코인3/5·EOS3/5·PBG)
# GAME_PLATFORM_POWERBALL_GAME_KEYS=coinpowerball3,coinpowerball5,eospowerball3,eospowerball,pbg
# 플레이어 /powerball 실시간 iframe. 비우면 GAME_KEY별 Bepick URL 자동 (v6 game_powerball_live 와 동일)
# GAME_PLATFORM_POWERBALL_LIVE_IFRAME_URL=
# 공급사가 Bearer 요구 시:
# GAME_PLATFORM_POWERBALL_BEARER_TOKEN=
# GAME_PLATFORM_POWERBALL_ODDS=1.95
# GAME_PLATFORM_POWERBALL_MIN_BET=1
# GAME_PLATFORM_POWERBALL_HTTP_TIMEOUT=10
# GAME_PLATFORM_POWERBALL_CONNECT_TIMEOUT=5
# GAME_PLATFORM_POWERBALL_HTTP_RETRIES=2
# 0이면 자동 수집 없음 → cron POST /internal/powerball/poll 또는 어드민 버튼만. 예: 60 = 60초마다 프로세스 내 poll
# GAME_PLATFORM_POWERBALL_POLL_INTERVAL_SEC=0
# 백그라운드 poll: 한 번 돌 때 실패 시 같은 틱 안에서 재시도(끊김 완화)
# GAME_PLATFORM_POWERBALL_POLL_MAX_ATTEMPTS_PER_TICK=12
# GAME_PLATFORM_POWERBALL_POLL_RETRY_DELAY_SEC=1
#
# 운영 점검 (헤더 X-Internal-Key: INTERNAL_API_KEY)
#   GET  /internal/game-apis/status   — 호스트·enabled 요약
#   GET  /internal/powerball/probe    — DB 안 건드리고 URL·키만 검증
#   POST /internal/powerball/poll     — 1회 수집+정산 (cron 권장)
# 예: * * * * * curl -sS -X POST -H "X-Internal-Key: $KEY" http://127.0.0.1:8100/internal/powerball/poll

# ═══ 토토·스포츠 외부 API (1단계: 연결 probe, 동기화 어댑터는 서비스 확장) ═══
# GAME_PLATFORM_TOTO_ENABLED=false
# GAME_PLATFORM_TOTO_API_BASE_URL=https://provider.example.com/api/v1
# GAME_PLATFORM_TOTO_BEARER_TOKEN=
# GAME_PLATFORM_TOTO_HTTP_TIMEOUT=15
# GAME_PLATFORM_TOTO_CONNECT_TIMEOUT=5
# GAME_PLATFORM_TOTO_PROBE_PATH=/health
# GAME_PLATFORM_TOTO_HTTP_RETRIES=2
#
#   GET /internal/toto/probe — 베이스+PROBE_PATH GET, JSON이면 preview_keys 반환

# ═══ The Odds API (the-odds-api.com) — 어드민 라이브 배당 ═══════════════════
# 키는 절대 Git 에 커밋하지 말 것. 무료 플랜은 월 쿼터 제한 → TTL 캐시 필수.
# GAME_PLATFORM_THE_ODDS_API_KEY=
# GAME_PLATFORM_THE_ODDS_API_BASE=https://api.the-odds-api.com
# GAME_PLATFORM_THE_ODDS_CACHE_TTL_SEC=60
# GAME_PLATFORM_THE_ODDS_REGIONS=uk,eu
# GAME_PLATFORM_THE_ODDS_BOOKMAKERS=
# GAME_PLATFORM_THE_ODDS_MAX_EVENTS_PER_SPORT=55
#
# 데모: 외부 Odds API 없이 공개 GET /api/mock-odds (JWT 없음). true 시 프로세스 내 5초마다 배당 틱.
# GAME_PLATFORM_USE_MOCK_SPORTS_ODDS=false
# GAME_PLATFORM_MOCK_SPORTS_ODDS_TICK_SEC=5
# GAME_PLATFORM_THE_ODDS_REQUEST_GAP_SEC=0.2
# 화면 표시 배당 = 원시 decimal × (1 - 마진%)
# GAME_PLATFORM_SPORTS_ODDS_MARGIN_PCT=2
#
# GET /admin/sports/odds-api/feed (JWT) — 60초 캐시, 주요 리그 다종목(코드 DEFAULT_SPORT_TARGETS)
# POST /admin/sports/matches/sync-from-odds-api?force_refresh=false — 피드→gp_sports_* 반영(쿼터 절약은 false 권장)

# 플레이어 가입 API 기본 테넌트 (gp_site_configs.site_id, 시드와 동일)
# NEXT_PUBLIC_DEFAULT_SITE_ID=a0000001-0000-4000-8000-000000000001

# ── 플레이어 웹 (web-public, 예: as.slotpass.net) ──────────────────────────
# 로컬: cd web-public && npm run dev  → http://localhost:3002
#
# 운영(nginx 뒤 공개 도메인): 반드시 `npm run build` 후 `npm run start -p 3002` 를 쓸 것.
# `next dev` 는 /_next/static/css/... 가 404 나는 환경이 있어 스타일·JS가 깨진 채로 보일 수 있음.
#
# [중요] 빌드만 하고 next 프로세스를 재시작하지 않으면, HTML이 가리키는 CSS 파일명과 디스크의 .next 가
#       어긋나 /_next/static/css/*.css 가 400 이 나와 디자인이 전부 빠진 것처럼 보일 수 있음.
#       배포: npm run build → next start(3002) 재시작 항상 같이.
#
# 배포 시(리버스 프록시가 as.slotpass.net → Node:3002 라면) web-public/.env.production 예시:
#   NEXT_PUBLIC_SITE_URL=https://as.slotpass.net
#   NEXT_PUBLIC_BUILD_STAMP=20260404a   # 파워볼 페이지 하단에 표시 → 운영이 최신 빌드인지 확인
#   API_PROXY_TARGET=http://127.0.0.1:8100
#   (또는 공인 API만 쓸 때: NEXT_PUBLIC_API_URL=https://test-api.slotpass.net — 이 경우 백엔드 CORS에 as 도메인 필요)
#
# 플레이어 웹 상단·/wallet: 고객센터·쪽지·관리자(백오피스) 외부 링크 — web-public `.env.local` / `.env.production` 에만 넣으면 됨.
#   NEXT_PUBLIC_PLAYER_SUPPORT_URL=https://t.me/your_support
#   NEXT_PUBLIC_PLAYER_MEMO_URL=https://community.example/bbs/memo.php
#   NEXT_PUBLIC_ADMIN_WEB_URL=https://test.slotpass.net
#
# FastAPI CORS: as.slotpass.net 은 main.py 에 명시 + *.slotpass.net 정규식으로 허용됨.
#
# Nginx 예시 (메인만 as 로):
#   server_name as.slotpass.net;
#   location / { proxy_pass http://127.0.0.1:3002; proxy_http_version 1.1;
#     proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme; }
#
# ── 어드민 web-admin (예: test.slotpass.net → :3000) ───────────────────────
# 메뉴 클릭 시 Server Error: Cannot find module './NNN.js' → .next 와 실행 중인 next start 가 불일치.
#   권장: cd web-admin && npm run build:clean   (또는 rm -rf .next && npm run build) 후 프로세스 재시작.
#   스크립트: web-admin/scripts/rebuild-and-note.sh
